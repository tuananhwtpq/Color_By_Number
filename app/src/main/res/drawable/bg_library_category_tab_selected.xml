<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <gradient
                android:angle="0"
                android:centerColor="#B2FFFFFF"
                android:endColor="#33FFFFFF"
                android:startColor="#33FFFFFF"
                android:type="linear" />
        </shape>
    </item>

    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="15dp" />
            <gradient
                android:angle="0"
                android:centerColor="#EE935D"
                android:endColor="#E27D69"
                android:startColor="#FFD633"
                android:type="linear" />
        </shape>
    </item>

</layer-list>
