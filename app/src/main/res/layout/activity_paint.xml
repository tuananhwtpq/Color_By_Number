<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/grey_50">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="10dp"
        android:contentDescription="Back"
        android:src="@drawable/ic_back_new"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/btnHint"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="20dp"
        android:src="@drawable/ic_hint_new"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/btnPreviewFull"
        style="@style/BodyM"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_gradien_oval"
        android:gravity="center"
        android:minWidth="72dp"
        android:paddingHorizontal="14dp"
        android:text="Full"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="@id/btnHint"
        app:layout_constraintEnd_toStartOf="@id/btnHint"
        app:layout_constraintTop_toTopOf="@id/btnHint" />

    <TextView
        android:id="@+id/tvHintCount"
        style="@style/BodyM"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="-8dp"
        android:background="@drawable/bg_gradien_oval"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:text="1"
        android:textColor="@color/white"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="@id/btnHint"
        app:layout_constraintEnd_toEndOf="@id/btnHint"
        tools:visibility="visible" />

    <!-- Canvas -->
    <com.example.baseproject.activities.PaintCanvasView
        android:id="@+id/paintCanvas"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        app:layout_constraintBottom_toTopOf="@id/paletteContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnHint" />

    <FrameLayout
        android:id="@+id/fullPreviewOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#CCF3F1F3"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/paletteContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnHint"
        tools:visibility="visible">

        <ImageView
            android:id="@+id/ivFullPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:adjustViewBounds="true"
            android:padding="16dp"
            android:scaleType="fitCenter"
            tools:src="@drawable/ic_hint_new" />

        <ImageView
            android:id="@+id/btnCloseFullPreview"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_gradien_oval"
            android:padding="10dp"
            android:src="@drawable/ic_close" />
    </FrameLayout>

    <!-- Loading overlay -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Palette -->
    <FrameLayout
        android:id="@+id/paletteContainer"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/grey_50"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:visibility="visible">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPalette"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:itemCount="5"
            tools:listitem="@layout/item_palette" />
    </FrameLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/llGuide"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_guide_01"
        android:elevation="4dp"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="gone">

        <TextView
            android:id="@+id/tvGuide01"
            style="@style/BodyL"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="160dp"
            android:background="@drawable/bg_text_guide"
            android:paddingHorizontal="20dp"
            android:paddingVertical="8dp"
            android:text="@string/pick_a_color_to_start_coloring"
            android:textColor="@color/grey_800"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:id="@+id/iv01"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-10dp"
            android:src="@drawable/img_poligon_02"
            app:layout_constraintEnd_toEndOf="@id/tvGuide01"
            app:layout_constraintStart_toStartOf="@id/tvGuide01"
            app:layout_constraintTop_toBottomOf="@id/tvGuide01" />

        <TextView
            android:id="@+id/tvGuide02"
            style="@style/BodyL"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="290dp"
            android:background="@drawable/bg_text_guide"
            android:paddingHorizontal="20dp"
            android:paddingVertical="8dp"
            android:text="@string/tap_the_matching_numbered_area_to_color"
            android:textColor="@color/grey_800"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/iv02"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-10dp"
            android:src="@drawable/img_poligon_02"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@id/tvGuide02"
            app:layout_constraintStart_toStartOf="@id/tvGuide02"
            app:layout_constraintTop_toBottomOf="@id/tvGuide02" />

        <TextView
            android:id="@+id/tvGuide03"
            style="@style/BodyL"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="160dp"
            android:layout_marginBottom="130dp"
            android:background="@drawable/bg_text_guide"
            android:paddingHorizontal="20dp"
            android:paddingVertical="8dp"
            android:text="@string/tap_here_if_you_can_t_find_the_color_area"
            android:textColor="@color/grey_800"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/iv03"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="-10dp"
            android:rotation="180"
            android:src="@drawable/img_poligon_02"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@id/tvGuide03"
            app:layout_constraintEnd_toEndOf="@id/tvGuide03" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
